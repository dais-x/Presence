[
  {
    "type": "speech",
    "text": "今仔日人咧菜市仔買菜去，"
  },
  {
    "type": "pause",
    "duration_ms": 317
  },
  {
    "type": "speech",
    "text": "伊欲著囝仔攜阮去，"
  },
  {
    "type": "speech",
    "text": "可是佇厝裡啦，"
  },
  {
    "type": "speech",
    "text": "囝仔誠在食飯，"
  },
  {
    "type": "speech",
    "text": "阿母閣在煮飯，"
  },
  {
    "type": "speech",
    "text": "我呢個時候就看著孫仔咧玩，"
  },
  {
    "type": "speech",
    "text": "有隻小雞按呢也在跟著佇後面追，"
  },
  {
    "type": "speech",
    "text": "桌上頂有碗米糕，"
  },
  {
    "type": "speech",
    "text": "旁邊還有一盤菜，"
  },
  {
    "type": "speech",
    "text": "真係好生動啦。"
  }
]
