[
  {
    "type": "speech",
    "text": "今仔日囝仔轉來厝內食飯，伊攏坐佇灶跤邊講話。"
  },
  {
    "type": "pause",
    "duration_ms": 277
  },
  {
    "type": "speech",
    "text": "孫仔咧搆欲食，阿母就煮些熱湯給伊。"
  },
  {
    "type": "speech",
    "text": "按呢大家嘔啦，真係好久未見到伊人。"
  },
  {
    "type": "speech",
    "text": "咱厝內今仔日氣氛誠好，歡喜極瞭齁。"
  }
