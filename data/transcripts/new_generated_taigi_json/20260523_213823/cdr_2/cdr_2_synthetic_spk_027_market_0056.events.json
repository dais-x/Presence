[
  {
    "type": "speech",
    "text": "今仔日去菜市仔買菜啦，"
  },
  {
    "type": "pause",
    "duration_ms": 1911
  },
  {
    "type": "speech",
    "text": "那個攤販咧賣好多菜啊，"
  },
  {
    "type": "pause",
    "duration_ms": 1174
  },
  {
    "type": "speech",
    "text": "我欲問伊青江豆幾錢一斤，"
  },
  {
    "type": "pause",
    "duration_ms": 1932
  },
  {
    "type": "speech",
    "text": "伊袂曉講啥物，"
  },
  {
    "type": "pause",
